{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

     "types": ["node"],

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
   "include": [
    "src"
  ],
  "exclude": ["node_modules", "dist"]
}